@page "/usuarios"
@layout MainLayout
@inject FirebaseService Firebase
@inject NavigationManager NavigationManager
@inject IMensajeToastr Toastr
@inject MudApp.Components.Helpers.UserSession Session

<PageTitle>Gestión de Usuarios</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" Class="mb-6" Color="Color.Success" Style="font-weight: bold;">Gestión de Usuarios</MudText>

    <MudTable Items="@_filteredUsers.Skip((_currentPage - 1) * _itemsPerPage).Take(_itemsPerPage)" Loading="@cargando" Dense="true" Hover="true" Bordered="false" Striped="true" Elevation="4" Class="rounded-xl overflow-hidden">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Lista de Usuarios</MudText>
            <MudSpacer />
            <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Value="@searchString1" Placeholder="Buscar usuario..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable="true" AutoComplete="off"></MudTextField>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" OnClick="NuevoUsuario" Class="rounded-lg px-6">Nuevo Usuario</MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Nombre</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Rol</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh Style="text-align:center">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Nombre">@context.NombreUsuario</MudTd>
            <MudTd DataLabel="Email">@context.CorreoElectronico</MudTd>
            <MudTd DataLabel="Rol">@(ObtenerNombreRol(context.IdRol))</MudTd>
            <MudTd DataLabel="Estado">
                <MudChip T="string" Color="@(context.EstaHabilitado ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Text">
                    @(context.EstaHabilitado ? "Habilitado" : "Deshabilitado")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:center">
                <div class="d-flex justify-center gap-2">
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => EditarUsuario(context))" />
                    </MudTooltip>
                    <MudTooltip Text="@(context.EstaHabilitado ? "Deshabilitar" : "Habilitar")">
                        <MudIconButton Icon="@(context.EstaHabilitado ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)" 
                                       Color="@(context.EstaHabilitado ? Color.Error : Color.Success)" 
                                       Size="Size.Small" 
                                       OnClick="@(() => ToggleEstado(context))" />
                    </MudTooltip>
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No se encontraron usuarios.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando usuarios...</MudText>
        </LoadingContent>
    </MudTable>

    <div class="d-flex justify-center mt-6">
        <MudPagination Color="Color.Success" SelectedChanged="PageChanged" Count="@_pageCount" Selected="@_currentPage" Class="pa-4"/>
    </div>
</MudContainer>

<Modal @ref="@modal" id="modalUsuario" bloquearCerrar="true" titulo="@(usuarioSeleccionado == null ? "Nuevo Usuario" : "Editar Usuario")" sizeModal="SizeModal.large">
    <ModalCreacionEdicionUsuarios 
        usuario="usuarioSeleccionado" 
        roles="roles" 
        onGuardar="async () => { await modal.CerrarModal(); await CargarDatos(); }">
    </ModalCreacionEdicionUsuarios>
</Modal>

@code {
    private List<UsuarioDTO> usuarios = new();
    private List<RolDTO> roles = new();
    private bool cargando = true;
    private string searchString1 = "";
    
    private int _currentPage = 1;
    private int _itemsPerPage = 10;
    private IEnumerable<UsuarioDTO> _filteredUsers => usuarios.Where(u => FilterFunc(u, searchString1));
    private int _pageCount => (int)Math.Ceiling((double)_filteredUsers.Count() / _itemsPerPage);

    private Modal modal = new();
    private UsuarioDTO? usuarioSeleccionado;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        try
        {
            var resRoles = await Firebase.ObtenerRolesAsync();
            if (resRoles != null && resRoles.Exito && resRoles.Datos != null)
            {
                roles = resRoles.Datos;
            }

            var resUsers = await Firebase.ObtenerUsuariosAsync();
            if (resUsers != null && resUsers.Exito && resUsers.Datos != null)
            {
                usuarios = resUsers.Datos.OrderBy(u => u.Id).ToList();
            }
        }
        catch (Exception ex)
        {
            await Toastr.MostrarMensajeError("Error al cargar datos: " + ex.Message);
        }
        finally
        {
            cargando = false;
        }
    }

    private void OnSearch(string text)
    {
        searchString1 = text;
        _currentPage = 1;
    }

    private void PageChanged(int i)
    {
        _currentPage = i;
    }

    private string ObtenerNombreRol(int idRol)
    {
        return roles.FirstOrDefault(r => r.Id == idRol)?.Descripcion ?? "Desconocido";
    }

    private bool FilterFunc(UsuarioDTO element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.NombreUsuario.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.CorreoElectronico.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task NuevoUsuario()
    {
        usuarioSeleccionado = null;
        await modal.AbrirModal();
    }

    private async Task EditarUsuario(UsuarioDTO user)
    {
        usuarioSeleccionado = user;
        await modal.AbrirModal();
    }

    private async Task ToggleEstado(UsuarioDTO user)
    {
        user.EstaHabilitado = !user.EstaHabilitado;
        var result = await Firebase.ActualizarUsuarioAsync(user.IdDocumento, user.NombreUsuario, user.CorreoElectronico, user.Contrasena, user.EstaHabilitado, user.IdRol);
        
        if (result.Exito)
        {
            await Toastr.MostrarMensajeExitoso(user.EstaHabilitado ? "Usuario habilitado" : "Usuario deshabilitado");
            StateHasChanged();
        }
        else
        {
            user.EstaHabilitado = !user.EstaHabilitado;
            await Toastr.MostrarMensajeError("No se pudo actualizar el estado: " + result.Mensaje);
        }
    }
}
