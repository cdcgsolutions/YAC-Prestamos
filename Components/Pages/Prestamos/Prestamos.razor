@page "/prestamos"
@layout MudApp.Components.Layout.MainLayout
@inject MudApp.Components.Services.FirebaseService Firebase
@inject NavigationManager NavigationManager
@inject MudApp.Components.Helpers.IMensajeToastr Toastr
@inject MudApp.Components.Helpers.UserSession Session

<PageTitle>Gestión de Préstamos</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: bold;">Gestión de Préstamos</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" OnClick="NuevoPrestamo" Class="rounded-lg px-6 shadow-md">Nuevo Préstamo</MudButton>
    </div>

    <MudPaper Class="pa-4 mb-6 rounded-xl shadow-sm" Elevation="2">
        <MudGrid Spacing="2" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
          <MudItem xs="12" md="4" Class="d-flex align-center">
            <MudTextField T="string" 
                          ValueChanged="@(s => OnSearch(s))" 
                          Value="@searchString" 
                          Label="Buscar Préstamos" 
                          Placeholder="Buscar por cliente o ID..." 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0 w-100" 
                          Clearable="true" 
                          Variant="Variant.Outlined" 
                          Margin="Margin.Dense">
            </MudTextField>
        </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string" ValueChanged="@OnFiltroEstadoChanged" Value="@filtroEstado" Label="Filtrar por Estado" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                    <MudSelectItem Value="@("Activo")">Activo</MudSelectItem>
                    <MudSelectItem Value="@("Pagado")">Pagado</MudSelectItem>
                    <MudSelectItem Value="@("Atrasado")">Atrasado</MudSelectItem>
                    <MudSelectItem Value="@("Anulado")">Anulado</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string" ValueChanged="@OnFiltroModalidadChanged" Value="@filtroModalidad" Label="Filtrar por Modalidad" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Todas")">Todas</MudSelectItem>
                    <MudSelectItem Value="@("Diario")">Diario</MudSelectItem>
                    <MudSelectItem Value="@("Semanal")">Semanal</MudSelectItem>
                    <MudSelectItem Value="@("Quincenal")">Quincenal</MudSelectItem>
                    <MudSelectItem Value="@("Mensual")">Mensual</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (cargando)
    {
        <div class="d-flex justify-center my-10">
            <MudProgressCircular Color="Color.Success" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (!_filteredPrestamos.Any())
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">No se encontraron préstamos con los filtros actuales.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var prestamo in _filteredPrestamos.Skip((_currentPage - 1) * _itemsPerPage).Take(_itemsPerPage))
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="4" Class="rounded-xl h-100 d-flex flex-column transition-transform mud-elevation-hover">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.h6" Style="font-weight: 600;">@prestamo.NombreCliente</MudText>
                                    <MudChip T="string" Color="@ObtenerColorEstado(prestamo.Estado)" Size="Size.Small" Variant="Variant.Filled" Class="font-weight-bold">@prestamo.Estado</MudChip>
                                </div>
                                <MudText Typo="Typo.caption" Color="Color.Default">ID: #@prestamo.Id | @prestamo.ModalidadCobro</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="flex-grow-1">
                            <MudDivider Class="mb-3" />
                            <div class="d-flex justify-space-between mb-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Monto Prestado</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: bold;">Bs. @prestamo.Monto.ToString("N2") (@prestamo.PorcentajeInteres%)</MudText>
                            </div>
                            <div class="d-flex justify-space-between mb-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Total a Pagar</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: bold;">Bs. @prestamo.MontoTotal.ToString("N2")</MudText>
                            </div>

                            
                            @{
                                double progreso = 0;
                                if (prestamo.MontoTotal > 0)
                                {
                                    progreso = (double)((prestamo.MontoTotal - prestamo.SaldoPendiente) / prestamo.MontoTotal) * 100;
                                }
                            }
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-space-between align-end mb-1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Progreso de pago</MudText>
                                    <MudText Typo="Typo.body2" Color="@(prestamo.SaldoPendiente > 0 ? Color.Error : Color.Success)" Style="font-weight: bold;">Saldo: Bs. @prestamo.SaldoPendiente.ToString("N2")</MudText>
                                </div>
                                <MudProgressLinear Color="@(progreso >= 100 ? Color.Success : Color.Warning)" Value="@progreso" Class="my-1" Size="Size.Medium" Rounded="true" />
                            </div>
                        </MudCardContent>
                        <MudCardActions Class="justify-end pa-4 pt-0">
                            <MudTooltip Text="Editar Préstamo">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Variant="Variant.Text" OnClick="@(() => EditarPrestamo(prestamo))" />
                            </MudTooltip>
                            <MudTooltip Text="Registrar Pago">
                                <MudIconButton Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Variant="Variant.Text" OnClick="@(() => AbrirModalPago(prestamo))" />
                            </MudTooltip>
                            <MudTooltip Text="Historial de Pagos">
                                <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Info" Variant="Variant.Text" OnClick="@(() => AbrirModalHistorial(prestamo))" />
                            </MudTooltip>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        <div class="d-flex justify-center mt-8 mb-6">
            <MudPagination Color="Color.Success" SelectedChanged="PageChanged" Count="@_pageCount" Selected="@_currentPage" Class="pa-4 shadow-sm rounded-xl" />
        </div>
    }
</MudContainer>

<Modal @ref="@modal" id="modalPrestamo" bloquearCerrar="true" titulo="@(prestamoSeleccionado == null ? "Nuevo Préstamo" : "Editar Préstamo")" sizeModal="SizeModal.large">
    <ModalCreacionEdicionPrestamos 
        prestamo="prestamoSeleccionado" 
        clientes="clientes"
        onGuardar="async () => { await modal.CerrarModal(); await CargarDatos(); }">
    </ModalCreacionEdicionPrestamos>
</Modal>

<Modal @ref="@modalPago" id="modalPago" bloquearCerrar="true" titulo="Registrar Pago" sizeModal="SizeModal.small">
    <ModalRegistrarPago 
        prestamo="prestamoSeleccionado" 
        onGuardar="async () => { await modalPago.CerrarModal(); await CargarDatos(); }">
    </ModalRegistrarPago>
</Modal>

<Modal @ref="@modalHistorial" id="modalHistorial" bloquearCerrar="true" titulo="Historial de Pagos" sizeModal="SizeModal.large">
    <ModalHistorialPagos 
        prestamo="prestamoSeleccionado">
    </ModalHistorialPagos>
</Modal>

<style>
    .mud-elevation-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@code {
    private List<MudApp.Components.DTOs.PrestamoDTO> prestamos = new();
    private List<MudApp.Components.DTOs.ClienteDTO> clientes = new();
    private bool cargando = true;
    
    // Filtros
    private string searchString = "";
    private string filtroEstado = "Todos";
    private string filtroModalidad = "Todas";
    
    // Paginación
    private int _currentPage = 1;
    private int _itemsPerPage = 9;
    
    private IEnumerable<MudApp.Components.DTOs.PrestamoDTO> _filteredPrestamos => prestamos.Where(p => FilterFunc(p));
    private int _pageCount => Math.Max(1, (int)Math.Ceiling((double)_filteredPrestamos.Count() / _itemsPerPage));

    private Modal modal = new();
    private Modal modalPago = new();
    private Modal modalHistorial = new();
    private MudApp.Components.DTOs.PrestamoDTO? prestamoSeleccionado;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        try
        {
            // Cargar clientes para el dropdown
            var resClientes = await Firebase.ObtenerClientesAsync();
            if (resClientes != null && resClientes.Exito && resClientes.Datos != null)
            {
                clientes = resClientes.Datos;
            }

            // Cargar préstamos
            var resPrestamos = await Firebase.ObtenerPrestamosAsync();
            if (resPrestamos != null && resPrestamos.Exito && resPrestamos.Datos != null)
            {
                prestamos = resPrestamos.Datos.OrderByDescending(p => p.Id).ToList();
            }
        }
        catch (Exception ex)
        {
            await Toastr.MostrarMensajeError("Error al cargar datos: " + ex.Message);
        }
        finally
        {
            cargando = false;
        }
    }

    private void OnSearch(string text)
    {
        searchString = text;
        _currentPage = 1;
    }
    
    private void OnFiltroEstadoChanged(string value)
    {
        filtroEstado = value;
        _currentPage = 1;
    }
    
    private void OnFiltroModalidadChanged(string value)
    {
        filtroModalidad = value;
        _currentPage = 1;
    }

    private void PageChanged(int i)
    {
        _currentPage = i;
    }

    private bool FilterFunc(MudApp.Components.DTOs.PrestamoDTO element)
    {
        // Filtro por Estado
        if (filtroEstado != "Todos" && element.Estado != filtroEstado)
            return false;
            
        // Filtro por Modalidad
        if (filtroModalidad != "Todas" && element.ModalidadCobro != filtroModalidad)
            return false;

        // Búsqueda de texto (Nombre o ID)
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
            
        if (element.NombreCliente.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
            
        if (element.Id.ToString().Contains(searchString))
            return true;
            
        return false;
    }

    private async Task NuevoPrestamo()
    {
        prestamoSeleccionado = null;
        await modal.AbrirModal();
    }

    private async Task EditarPrestamo(MudApp.Components.DTOs.PrestamoDTO p)
    {
        prestamoSeleccionado = p;
        await modal.AbrirModal();
    }

    private async Task AbrirModalPago(MudApp.Components.DTOs.PrestamoDTO p)
    {
        prestamoSeleccionado = p;
        await modalPago.AbrirModal();
    }

    private async Task AbrirModalHistorial(MudApp.Components.DTOs.PrestamoDTO p)
    {
        prestamoSeleccionado = p;
        await modalHistorial.AbrirModal();
    }

    private Color ObtenerColorEstado(string estado)
    {
        return estado switch
        {
            "Activo" => Color.Success,
            "Pagado" => Color.Info,
            "Atrasado" => Color.Error,
            "Anulado" => Color.Dark,
            _ => Color.Default
        };
    }
}
