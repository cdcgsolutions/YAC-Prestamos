@page "/registro"
@layout EmptyLayout
@using System.Text.RegularExpressions
@inject IJSRuntime JS
@inject IMensajeToastr Toastr
@inject NavigationManager NavigationManager

<PageTitle>Registro de nuevos usuarios</PageTitle>

<div class="d-flex justify-center align-center mud-width-full mud-background-gray" style="min-height: 100vh; background: var(--mud-palette-background);">
    <MudContainer MaxWidth="MaxWidth.Small" Class="px-4">
        <MudCard Elevation="25" Class="pa-4 pa-sm-8 rounded-xl mud-width-full">
            <MudCardHeader Class="d-flex justify-center pb-0">
                <CardHeaderContent>
                    <div class="d-flex flex-column align-center text-center">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Success" Style="font-size: 64px;" />
                        <MudText Typo="Typo.h4" Class="mt-2" Color="Color.Success" Style="font-weight: bold;">Crear Usuario</MudText>
                        <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mb-4">Registro en el Sistema</MudText>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="nombreUsuario" Label="Nombre Completo" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                
                <MudTextField @bind-Value="email" Label="Correo Electrónico" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                
                <MudTextField @bind-Value="contrasena" Label="Contraseña" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="@tipoEntradaContrasena"
                              Adornment="Adornment.End" AdornmentIcon="@iconoEntradaContrasena" OnAdornmentClick="AlternarVisibilidadContrasena" AdornmentAriaLabel="Mostrar contraseña" Class="mb-4"/>
                
                <MudTextField @bind-Value="confirmarContrasena" Label="Confirmar Contraseña" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="@tipoEntradaContrasena"
                              Adornment="Adornment.End" AdornmentIcon="@iconoEntradaContrasena" OnAdornmentClick="AlternarVisibilidadContrasena" AdornmentAriaLabel="Mostrar contraseña" Class="mb-4"/>
            </MudCardContent>
            <MudCardActions Class="d-flex flex-column align-stretch px-4 pb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" Class="rounded-lg py-2" OnClick="Registrar" Disabled="@cargando">
                    @if (cargando)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">Creando...</MudText>
                    }
                    else
                    {
                        <MudText>Crear Usuario</MudText>
                    }
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" Class="mt-2" OnClick="VolverAlLogin">
                    Volver al Inicio
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudContainer>
</div>

@code {
    private string nombreUsuario = "";
    private string email = "";
    private string contrasena = "";
    private string confirmarContrasena = "";
    private bool estaHabilitado = true;
    private bool cargando = false;

    private bool mostrarContrasena;
    private InputType tipoEntradaContrasena = InputType.Password;
    private string iconoEntradaContrasena = Icons.Material.Filled.VisibilityOff;

    private IJSObjectReference? _firebaseModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _firebaseModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/firebase-interop.js");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error cargando Firebase: " + ex.Message);
            }
        }
    }

    private void AlternarVisibilidadContrasena()
    {
        mostrarContrasena = !mostrarContrasena;
        if (mostrarContrasena)
        {
            iconoEntradaContrasena = Icons.Material.Filled.Visibility;
            tipoEntradaContrasena = InputType.Text;
        }
        else
        {
            iconoEntradaContrasena = Icons.Material.Filled.VisibilityOff;
            tipoEntradaContrasena = InputType.Password;
        }
    }

    private async Task Registrar()
    {
        if (string.IsNullOrWhiteSpace(nombreUsuario) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(contrasena))
        {
            await Toastr.MostrarMensajeWarning("Por favor, llene todos los campos (Nombre, Correo y Contraseña).");
            return;
        }

        if (contrasena != confirmarContrasena)
        {
            await Toastr.MostrarMensajeError("Las contraseñas no coinciden.");
            return;
        }

        if (!email.Contains("@") || !email.Contains("."))
        {
            await Toastr.MostrarMensajeError("Por favor, ingrese un correo electrónico válido que contenga '@'.");
            return;
        }

        var regexPassword = new Regex(@"^(?=.*[a-zA-Z])(?=.*\d)(?=.*[^a-zA-Z\d]).{6,}$");
        if (!regexPassword.IsMatch(contrasena))
        {
            await Toastr.MostrarMensajeWarningWithTitle("La contraseña debe tener al menos 6 caracteres, ser alfanumérica y contener un carácter especial (ej. !@#$%).", "Contraseña Insegura");
            return;
        }

        if (_firebaseModule == null)
        {
            await Toastr.MostrarMensajeError("Firebase no ha terminado de cargar.");
            return;
        }

        cargando = true;
        StateHasChanged();

        try
        {
            var result = await _firebaseModule.InvokeAsync<ResultadoRegistro>("registrarUsuario", nombreUsuario, email, contrasena, estaHabilitado);

            if (result != null && result.Exito)
            {
                await Toastr.MostrarMensajeExitosoWithTitle(result.Mensaje ?? "Usuario creado exitosamente", "¡Éxito!");
                nombreUsuario = "";
                email = "";
                contrasena = "";
                confirmarContrasena = "";
                estaHabilitado = true;
            }
            else
            {
                await Toastr.MostrarMensajeErrorWithTitle(result?.Mensaje ?? "Error al registrar usuario", "Error");
            }
        }
        catch (Exception ex)
        {
            await Toastr.MostrarMensajeErrorWithTitle("Error inesperado: " + ex.Message, "Error Crítico");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void VolverAlLogin()
    {
        NavigationManager.NavigateTo("/", replace: true);
    }
}
